[include]
  path = ~/.gitconfig_local
[advice]
  detachedHead = false
  statusHints = false
[color]
  ui = auto
[commit]
  verbose = true
[core]
  excludesFile = ~/.config/git/ignore
  ignorecase = true
[fetch]
  prune = true
[init]
	defaultBranch = main
[merge]
  conflictstyle = zdiff3
[pull]
  rebase = true
[push]
  autoSetupRemote = true
[rebase]
  autoSquash = true
  autoStash = true
  updateRefs = true
[rerere]
  enable = true
  autoupdate = true
[credential]
	helper = !gh auth git-credential
