# --- Editors ---
export EDITOR=nvim
export VISUAL=$EDITOR
export GIT_EDITOR="$EDITOR"

# --- Language/tooling env ---
# Elixir/Erlang
export KERL_BUILD_DOCS="yes"
export ERL_AFLAGS="-kernel shell_history enabled"

# Go
export GOPATH=$HOME/go
export GOPROXY=direct

# Shell path
export SHELL=/bin/zsh

export HELIX_RUNTIME=$HOME/Developer/helix/runtime
export OPENCODE_DISABLE_AUTOCOMPACT=1

# Use zsh's path array and dedupe to avoid duplicates and keep order
typeset -U path
path=(
  /opt/homebrew/bin
  $HOME/bin
  /usr/local/bin
  $HOME/go/bin
  $HOME/.cargo/bin
  $HOME/.bun/bin
  $HOME/.local/share/nvim/mason/bin
  $HOME/.opencode/bin
  $HOME/.local/bin
  $path
)

# Homebrew-provided client CLIs 
if command -v brew >/dev/null 2>&1; then
  local brew_prefix="$(brew --prefix)"
  local brew_dirs=("libpq/bin" "mysql-client/bin")
  for brew_dir in "${brew_dirs[@]}"; do
    if [ -d "$brew_prefix/opt/$brew_dir" ]; then
      path=("$brew_prefix/opt/$brew_dir" $path)
    fi
  done
fi

export PATH

# --- Shell Options ---
setopt autocd correct

# --- Aliases ---
alias ls="eza --icons=always"
alias lg=lazygit
alias chez=chezmoi
alias code=code-insiders
alias dbui="nvim -c DBUI"
alias nv=nvim

export ZSH_CACHE_DIR=$HOME/.cache/zsh

# --- Core Configuration  ---
source "$HOME/.zsh/completion.zsh"
source "$HOME/.zsh/history.zsh"

# --- Initialize completions after path setup ---
autoload -Uz compinit; compinit

fpath=(
  $HOME/.zsh
  $HOME/.cache/zsh/completions
  $fpath
)

# --- Conditional Plugin Loading ---
# Load brew plugin if brew is available
if command -v brew >/dev/null 2>&1; then
  source "$HOME/.zsh/brew.plugin.zsh"
fi

# Load git-related plugins if git is available
if command -v git >/dev/null 2>&1; then
  source "$HOME/.zsh/git.plugin.zsh"
  source "$HOME/.zsh/gh.plugin.zsh"
fi

# Load tool-specific plugins if commands are available
command -v bun >/dev/null 2>&1 && source "$HOME/.zsh/bun.plugin.zsh"
command -v chezmoi >/dev/null 2>&1 && source "$HOME/.zsh/chezmoi.plugin.zsh"
command -v mise >/dev/null 2>&1 && source "$HOME/.zsh/mise.plugin.zsh"
command -v zoxide >/dev/null 2>&1 && source "$HOME/.zsh/zoxide.plugin.zsh"

# Load fzf plugin 
source "$HOME/.zsh/fzf.plugin.zsh"

# Load history plugin
source "$HOME/.zsh/history.plugin.zsh"

# --- Lazy Loading for Heavy Components ---
autoload -Uz add-zsh-hook

lazy_load_starship() {
  if ! typeset -f starship_prompt >/dev/null 2>&1; then
    # Prevent multiple initializations in current session only
    if [[ -z "$STARSHIP_INITIALIZED" ]]; then
      STARSHIP_INITIALIZED=1
      eval "$(starship init zsh)"
    fi
  fi
}

lazy_load_syntax_highlighting() {
  if ! typeset -f _zsh_highlight >/dev/null 2>&1; then
    source "$HOME/.zsh/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
  fi
}

# Hook lazy loading into prompt
add-zsh-hook precmd lazy_load_starship
add-zsh-hook precmd lazy_load_syntax_highlighting

# --- Key Bindings and History ---
bindkey -v
export KEYTIMEOUT=1

# Enable Ctrl+P/N for history navigation in insert mode
bindkey '^P' up-line-or-history
bindkey '^N' down-line-or-history

eval "$(varset hook zsh)"

# Fix for starship recursion issue
export FUNCNEST=1000

# --- Local overrides ---
[ -f "$HOME/.zshrc.local" ] && . "$HOME/.zshrc.local"
fpath=(~/.local/share/zsh/completions $fpath)
autoload -U compinit && compinit
