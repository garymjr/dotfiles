# Allow read-only GitHub CLI inspection commands without approval.
prefix_rule(
    pattern = ["gh", "auth", "status"],
    decision = "allow",
    justification = "Allows read-only GitHub authentication status inspection via gh CLI.",
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
    justification = "Allows read-only GitHub repository inspection via gh CLI.",
)

prefix_rule(
    pattern = ["gh", "pr", ["view", "list", "status", "checks", "diff"]],
    decision = "allow",
    justification = "Allows read-only GitHub PR inspection via gh CLI.",
)

prefix_rule(
    pattern = ["gh", "issue", ["view", "list"]],
    decision = "allow",
    justification = "Allows read-only GitHub issue inspection via gh CLI.",
)

prefix_rule(
    pattern = ["gh", "run", ["view", "list"]],
    decision = "allow",
    justification = "Allows read-only GitHub Actions run inspection via gh CLI.",
)

prefix_rule(
    pattern = ["gh", "workflow", ["view", "list"]],
    decision = "allow",
    justification = "Allows read-only GitHub Actions workflow inspection via gh CLI.",
)

prefix_rule(
    pattern = ["gh", "release", ["view", "list"]],
    decision = "allow",
    justification = "Allows read-only GitHub release inspection via gh CLI.",
)

# Allow read-only AWS CLI inspection commands without approval.
prefix_rule(
    pattern = ["aws", "configure", "get"],
    decision = "allow",
    justification = "Allows local AWS profile configuration inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "sts", "get-caller-identity"],
    decision = "allow",
    justification = "Allows read-only AWS caller identity checks via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "ec2", "describe-regions"],
    decision = "allow",
    justification = "Allows read-only AWS region inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "ecr", ["describe-repositories", "list-images"]],
    decision = "allow",
    justification = "Allows read-only AWS ECR repository and image inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "cloudwatch", "describe-alarms"],
    decision = "allow",
    justification = "Allows read-only AWS CloudWatch alarm inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "ec2", "describe-route-tables"],
    decision = "allow",
    justification = "Allows read-only AWS route table inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "rds", "describe-db-instances"],
    decision = "allow",
    justification = "Allows read-only AWS RDS instance inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "ssm", "get-command-invocation"],
    decision = "allow",
    justification = "Allows read-only AWS SSM command result inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "ecs", "describe-services"],
    decision = "allow",
    justification = "Allows read-only AWS ECS service inspection via aws CLI.",
)

prefix_rule(
    pattern = ["aws", "elbv2", "describe-target-health"],
    decision = "allow",
    justification = "Allows read-only AWS target health inspection via aws CLI.",
)


# Allow creating a local feature branch after the user has approved the branch change.
prefix_rule(
    pattern = ["git", "switch", "-c"],
    decision = "allow",
    justification = "Allows Git to create slash-separated feature branch refs inside .git after explicit user approval.",
)

prefix_rule(
    pattern = ["git", "add"],
    decision = "allow",
    justification = "Allows Git to stage files after explicit user approval.",
)

prefix_rule(
    pattern = ["git", "commit"],
    decision = "allow",
    justification = "Allows Git to create local commits after explicit user approval.",
)

prefix_rule(
    pattern = ["git", "fetch", "origin"],
    decision = "allow",
    justification = "Allows read-only Git fetches from origin after explicit user approval.",
)

prefix_rule(
    pattern = ["git", "status"],
    decision = "allow",
    justification = "Allows read-only Git status checks during local workflow inspection.",
)

prefix_rule(
    pattern = ["git", "push"],
    decision = "allow",
    justification = "Allows Git pushes to complete remote updates and local index bookkeeping without sandbox metadata failures after explicit user approval.",
)
